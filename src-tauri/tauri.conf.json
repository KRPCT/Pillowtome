{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pillowtome",
  "version": "1.0.1",
  "identifier": "com.pillowtome.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "枕籍 Pillowtome",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' blob: ipc: http://ipc.localhost",
        "frame-src": "'self' blob:",
        "child-src": "'self' blob:",
        "worker-src": "'self' blob:",
        "connect-src": "'self' blob: data: ipc: http://ipc.localhost http://pillow.localhost https://pillow.localhost pillow:",
        "img-src": "'self' asset: data: blob: ipc: http://ipc.localhost http://pillow.localhost https://pillow.localhost pillow:",
        "media-src": "'self' asset: data: blob: ipc: http://ipc.localhost http://pillow.localhost https://pillow.localhost pillow:",
        "style-src": "'self' 'unsafe-inline' blob: http://pillow.localhost https://pillow.localhost pillow:",
        "font-src": "'self' data: blob: http://pillow.localhost https://pillow.localhost pillow:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "android": {
      "minSdkVersion": 26
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
